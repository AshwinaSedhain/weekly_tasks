# Copy this file to .env and fill in your values
# docker-compose reads from .env automatically

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=healthstream
DB_USER=healthstream
DB_PASSWORD=healthstream123

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW_CLAIMS=raw-claims
KAFKA_TOPIC_VALIDATED_CLAIMS=validated-claims
KAFKA_TOPIC_FRAUD_ALERTS=fraud-alerts

# Data Generator
BATCH_SIZE=30
GENERATION_INTERVAL=3
NUM_PATIENTS=200
NUM_HOSPITALS=20
FRAUD_RATE=0.05

# Fraud threshold (0.0 to 1.0)
FRAUD_THRESHOLD=0.7

# Dashboard
API_BASE_URL=http://api:8000
REFRESH_INTERVAL=30

# Airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin123
